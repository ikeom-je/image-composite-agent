# ============================================================
# .env.local.example — 個人設定のテンプレート
# このファイルをコピーして .env.local を作成し、実際の値を設定する
# .env.local は .gitignore で追跡除外済み（コミット禁止）
# ============================================================

# AWS設定
AWS_PROFILE=your-aws-profile-name
AWS_DEFAULT_REGION=us-east-1
CDK_DEFAULT_REGION=us-east-1

# Embedding モデル設定（変更不要）
EMBEDDING_MODEL_ID=twelvelabs.marengo-embed-2-7-v1:0

# Strands Agent が使用するBedrockモデル（推論プロファイルID）
AGENTMODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# デプロイ環境（dev / staging / prod）
ENVIRONMENT=dev

# デプロイ後に実際の値を設定してください
FRONTEND_URL=https://<YOUR_CLOUDFRONT_DOMAIN>.cloudfront.net
API_GATEWAY_URL=https://<YOUR_API_GW_ID>.execute-api.us-east-1.amazonaws.com/dev
