{
  "name": "image-processor-api",
  "version": "2.5.5",
  "description": "Advanced Image Composition REST API with Alpha Channel Support",
  "author": "AWS CDK Team",
  "license": "MIT",
  "keywords": [
    "aws",
    "cdk",
    "lambda",
    "api-gateway",
    "image-processing",
    "pillow",
    "python",
    "uv",
    "alpha-channel"
  ],
  "bin": {
    "image-processor-api": "bin/image-processor-api.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "test/run-tests.sh",
    "test:comprehensive": "test/run-comprehensive-tests.sh",
    "test:lambda": "source .venv/bin/activate && cd test/lambda && python -m unittest test_image_processor.py test_upload_manager.py && deactivate",
    "test:api": "test/run-api-tests.sh",
    "test:api:report": "npx playwright test --config=test/playwright.config.ts --project=api-tests",
    "test:frontend": "FRONTEND_URL=http://localhost:8080 npx playwright test --config=test/playwright.config.ts test/e2e/frontend.spec.ts --reporter=list",
    "test:upload": "npx playwright test --config=test/playwright.config.ts --project=upload-tests --reporter=list",
    "test:selection": "npx playwright test --config=test/playwright.config.ts --project=selection-tests --reporter=list",
    "test:integration": "npx playwright test --config=test/playwright.config.ts --project=integration-tests --reporter=list",
    "test:all-e2e": "npm run test:upload && npm run test:selection && npm run test:integration",
    "test:api-validation": "npx playwright test --config=test/playwright-api.config.ts test/e2e/api-validation.api.spec.ts --reporter=list",
    "test:upload-api": "npx playwright test --config=test/playwright-api.config.ts test/e2e/upload-api-validation.api.spec.ts --reporter=list",
    "test:upload-comprehensive": "npx playwright test --config=test/playwright-api.config.ts test/e2e/upload-comprehensive.api.spec.ts --reporter=list",
    "test:image-selection": "npx playwright test --config=test/playwright-api.config.ts test/e2e/image-selection-simple.api.spec.ts --reporter=list",
    "test:integration-e2e": "npx playwright test --config=test/playwright-api.config.ts test/e2e/integration-e2e.api.spec.ts --reporter=list",
    "test:api-all": "npm run test:api-validation && npm run test:upload-api",
    "test:api-comprehensive": "test/run-comprehensive-api-tests.sh",
    "regenerate-expected-images": "python3 scripts/regenerate-expected-images.py",
    "fix-test-assets": "python3 scripts/fix-test-assets.py",
    "cdk": "cdk",
    "deploy": "npm run build && cdk deploy --all --require-approval never && npm run post-deploy",
    "deploy:api": "cdk deploy ImageProcessorApiStack --require-approval never",
    "deploy:frontend": "cdk deploy ImageCompositeViewerStack --require-approval never",
    "post-deploy": "echo 'Frontend deployment is now handled by CDK'",
    "destroy": "cdk destroy --all",
    "destroy:api": "cdk destroy ImageProcessorApiStack",
    "destroy:frontend": "cdk destroy ImageCompositeViewerStack",
    "synth": "cdk synth",
    "synth:api": "cdk synth ImageProcessorApiStack",
    "synth:frontend": "cdk synth ImageCompositeViewerStack",
    "diff": "cdk diff",
    "diff:api": "cdk diff ImageProcessorApiStack",
    "diff:frontend": "cdk diff ImageCompositeViewerStack",
    "build-frontend": "cd frontend && npm install && npm run build",
    "deploy-all": "npm run deploy",
    "setup-env": "source scripts/setup-env.sh",
    "env": "source scripts/setup-env.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.7.9",
    "aws-cdk": "2.1019.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.110.0",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21"
  }
}
