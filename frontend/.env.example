# 画像合成REST API フロントエンド環境変数設定例

# API エンドポイント URL（CDKデプロイ後に設定）
# 例: https://your-api-id.execute-api.ap-northeast-1.amazonaws.com/prod/images/composite
VITE_API_URL=

# アップロード API エンドポイント URL（CDKデプロイ後に設定）
# 例: https://your-api-id.execute-api.ap-northeast-1.amazonaws.com/prod/upload
VITE_UPLOAD_API_URL=

# CloudFront ディストリビューション URL（CDKデプロイ後に設定）
# 例: https://your-distribution-id.cloudfront.net
VITE_CLOUDFRONT_URL=

# 環境設定
VITE_ENVIRONMENT=development

# デバッグモード（開発時のみ）
VITE_DEBUG_MODE=true